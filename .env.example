OPENAI_API_KEY=
LLM_PROVIDER=openai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_KEEP_ALIVE=0m
OLLAMA_NUM_CTX=1024
OLLAMA_NUM_BATCH=4
OLLAMA_NUM_PREDICT=256
OLLAMA_MAX_CONCURRENT_REQUESTS=1
OLLAMA_MAX_RETRIES=3
OLLAMA_RESTART_ON_FAILURE=true
OLLAMA_START_TIMEOUT_SECONDS=45
OLLAMA_RETRY_BACKOFF_SECONDS=3
OLLAMA_COMMAND=ollama
USE_OPENAI_FALLBACK=false
LOCAL_CONFIDENCE_THRESHOLD=0.75

LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_TOTP_SECRET=
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=

GOOGLE_EMAIL=
GOOGLE_PASSWORD=
GOOGLE_TOTP_SECRET=

BROWSER_EXECUTABLE_PATH=
BROWSER_CHANNEL=
LINKEDIN_PROFILE_DIR=.secrets/linkedin-profile
LINKEDIN_STORAGE_STATE=.secrets/linkedin-state.json
FIREFOX_EXTENSION_PROFILE_DIR=

# If Firefox is already logged into LinkedIn, the tool will automatically
# import current .linkedin.com cookies from your default Firefox profile.
# You should usually leave LINKEDIN_LI_AT and LINKEDIN_JSESSIONID blank.

HEADLESS=true
ENABLE_PROGRESS_GUI=true
STATUS_HEARTBEAT_SECONDS=120
LINKEDIN_MANUAL_REVIEW_MODE=true
LINKEDIN_CAPTURE_MODE=playwright
LINKEDIN_EXTENSION_BRIDGE_HOST=127.0.0.1
LINKEDIN_EXTENSION_BRIDGE_PORT=8765
LINKEDIN_EXTENSION_CAPTURE_TIMEOUT_SECONDS=120
LINKEDIN_EXTENSION_HISTORY_TIMEOUT_SECONDS=30
LINKEDIN_EXTENSION_AUTO_OPEN_SEARCH_TABS=true

JOB_SEARCH_TIMEZONE=America/Chicago
JOB_SEARCH_COUNTRY=US
JOB_SEARCH_CITY=Chicago
JOB_SEARCH_REGION=Illinois

MIN_BASE_SALARY_USD=200000
POSTED_WITHIN_DAYS=14
MINIMUM_QUALIFYING_JOBS=10
TARGET_JOB_COUNT=10
MAX_ADAPTIVE_SEARCH_PASSES=3
MAX_SEARCH_ROUNDS=3
SEARCH_ROUND_QUERY_LIMIT=6
MAX_LEADS_PER_QUERY=6
MAX_LEADS_TO_RESOLVE_PER_PASS=60
PER_QUERY_TIMEOUT_SECONDS=35
PER_LEAD_TIMEOUT_SECONDS=25

MAX_LINKEDIN_RESULTS_PER_COMPANY=25
MAX_LINKEDIN_PAGES_PER_COMPANY=3

DAILY_RUN_HOUR=8
DAILY_RUN_MINUTE=0
